    {
      "name": "Auth",
      "item": [
        {
          "name": "login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseData = pm.response.json();\r",
                  "\r",
                  "pm.environment.set(\"auth_token\", responseData.accessToken);\r",
                  "\r",
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response body contains an access Token (string)\", () => {\r",
                  "    pm.expect(responseData.accessToken).to.be.a('string');\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
