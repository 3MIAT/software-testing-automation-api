<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Assignment2 - Software Testing Suite" verbose="1" parallel="none">

    <listeners>
        <listener class-name="com.automation.listeners.AllureListener"/>
    </listeners>

    <!-- ─── Part A: UI Automation Tests ─────────────────────── -->

    <test name="Registration Tests">
        <classes>
            <class name="com.automation.tests.TC01_RegisterWithoutErrors"/>
            <class name="com.automation.tests.TC02_RegisterWithErrors"/>
        </classes>
    </test>

    <test name="Authentication Tests">
        <classes>
            <class name="com.automation.tests.TC03_ValidLogin"/>
            <class name="com.automation.tests.TC04_InvalidLogin"/>
        </classes>
    </test>

    <test name="Navigation and Catalog Tests">
        <classes>
            <class name="com.automation.tests.TC05_ChangeCurrency"/>
            <class name="com.automation.tests.TC06_BreadcrumbAndMenu"/>
            <class name="com.automation.tests.TC07_SortByName"/>
        </classes>
    </test>

    <test name="Search Tests">
        <classes>
            <class name="com.automation.tests.TC08_SearchByName"/>
            <class name="com.automation.tests.TC09_SearchInSubcategories"/>
        </classes>
    </test>

    <test name="Cart and Checkout Tests">
        <classes>
            <class name="com.automation.tests.TC10_AddToCart"/>
            <class name="com.automation.tests.TC11_Checkout"/>
        </classes>
    </test>

</suite>
